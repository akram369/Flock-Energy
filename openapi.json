{
  "openapi": "3.1.0",
  "info": {
    "title": "Flock Energy - Urja Meter Ops API",
    "description": "Clean, modern, documented REST API wrapping the legacy Urja Meter Ops portal. Serves a dashboard UI at /.",
    "version": "1.0.0"
