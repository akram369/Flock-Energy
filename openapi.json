              "title": "Q"
            },
            "description": "Search search query for meter ID or serial number"
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by installation status (Active, Decommissioned, etc.)",
